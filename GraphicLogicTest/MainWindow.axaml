<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GraphicLogicTest"
        x:Class="GraphicLogicTest.MainWindow"
        x:DataType="local:MainWindow"
        Title="GEffects Logic Test"
        Height="900"
        Width="1800">
    <Grid Background="Black" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Margin="16,10,0,8"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Text="GEffects Logic Test Bench" />

        <Border Grid.Row="1" Margin="0" Background="Transparent">
            <ContentControl Content="{Binding ActiveWindowContent}" />
        </Border>

        <Border Grid.Row="2" Background="#FF151515" BorderBrush="#FF505050" BorderThickness="1,1,1,0" Padding="10,8">
            <ItemsControl ItemsSource="{Binding WindowViews}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Title}"
                                Tag="{Binding Index}"
                                Click="SelectWindow_Click"
                                Background="{Binding ButtonBackground}"
                                Foreground="White" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>