<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="GraphicLogicTest.Views.SecondaryView">
	<Border Margin="12,8,12,12"
			Background="#FF1E1E1E"
			BorderBrush="#FF505050"
			BorderThickness="1"
			CornerRadius="4">
		<TextBlock HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   Foreground="White"
				   FontSize="18"
				   Text="Second window (empty for now)"/>
	</Border>
</UserControl>
